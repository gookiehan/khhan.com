---
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import Section from '../components/Section.astro';
import FileLinks from '../components/FileLinks.astro';
import ListSection from '../components/ListSection.astro';
import QeaSection from '../components/QeaSection.astro';
import PublicationsSection from '../components/PublicationsSection.astro';
import ActivitiesSection from '../components/ActivitiesSection.astro';

function loadYaml(fileName) {
  const fullPath = path.join(process.cwd(), 'src', 'data', fileName);
  const source = fs.readFileSync(fullPath, 'utf8');
  return yaml.load(source);
}

const qeaData = loadYaml('qea.yml');
const educationData = loadYaml('education.yml');
const careerData = loadYaml('career.yml');
const researchData = loadYaml('research.yml');
const awardsData = loadYaml('awards.yml');
const activitiesData = loadYaml('activities.yml');
const publicationsData = loadYaml('publications.yml');
const patentsData = loadYaml('patents.yml');
const honorsData = loadYaml('honors.yml');
const taData = loadYaml('ta.yml');
const clubsData = loadYaml('clubs.yml');
const profileData = loadYaml('profile.yml');

const qeaAbstract = qeaData.qeaAbstract;
const qeaThesis = qeaData.qeaThesis;
const qeaJournals = qeaData.qeaJournals;
const qeaConferences = qeaData.qeaConferences;
const qeaDomestic = qeaData.qeaDomestic;
const qeaPatent = qeaData.qeaPatent;

const education = educationData.education;
const career = careerData.career;
const researchInterests = researchData.researchInterests;
const projects = researchData.projects;
const awards = awardsData.awards;
const activities = activitiesData.activities;
const phdThesis = publicationsData.phdThesis;
const intlJournals = publicationsData.intlJournals;
const intlConferences = publicationsData.intlConferences;
const domesticPapers = publicationsData.domesticPapers;
const magazineArticles = publicationsData.magazineArticles;
const books = publicationsData.books;
const patentNote = patentsData.patentNote;
const patentSearchUrls = patentsData.patentSearchUrls;
const honors = honorsData.honors;
const taActivities = taData.taActivities;
const clubs = clubsData.clubs;
const scholarUrl = profileData.scholarUrl;

function escapeHtml(value) {
  return String(value)
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');
}

const educationItems = education.map((e) => ({
  period: e.period,
  titleHtml: `${e.title}, <a href="${e.orgUrl}" target="_blank">${e.org}</a>`,
  descHtml: e.desc,
  files: e.files,
}));

const careerItems = career.map((c) => ({
  period: c.period,
  titleHtml: c.title,
  descHtml: c.desc || '',
  files: c.files,
}));

const projectsItems = projects.map((p) => ({
  period: p.period,
  titleHtml: p.title,
  descHtml: `${p.org} / ${p.role}`,
  files: p.files,
}));

const awardsItems = awards.map((a) => ({
  period: a.date,
  titleHtml: a.title,
  descHtml: '',
  files: a.files,
}));

const boardItems = activities.board.map((b) => ({
  period: b.period,
  titleHtml: b.title,
  descHtml: '',
  files: b.files ?? [],
}));

const committeeItems = activities.committee.map((c) => ({
  period: c.period,
  titleHtml: c.title,
  descHtml: '',
  files: c.files ?? [],
}));

const standardizationItems = activities.standardization.map((s) => ({
  period: s.period,
  titleHtml: s.title,
  descHtml: '',
  files: s.files ?? [],
}));

const talksItems = activities.invitedTalks.map((t) => ({
  period: t.date,
  titleHtml: t.title,
  descHtml: '',
  files: t.files,
}));

const teachingItems = activities.teaching.map((t) => ({
  period: t.date,
  titleHtml: t.title,
  descHtml: '',
  files: t.files ?? [],
}));

const judgesItems = activities.judges.map((j) => ({
  period: j.period,
  titleHtml: j.title,
  descHtml: '',
  files: j.files ?? [],
}));

const taItems = taActivities.map((t) => ({
  period: t.period,
  titleHtml: t.title,
  descHtml: '',
  files: t.files,
}));

const clubsItems = clubs.map((c) => ({
  period: '',
  titleHtml: c.title,
  descHtml: c.desc,
  files: c.files ?? [],
}));
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>한국현 – Kuk-Hyun Han</title>
    <link rel="stylesheet" href="style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700&display=swap" rel="stylesheet">
  </head>

  <body>
    <!-- NAV -->
    <nav>
      <div class="inner">
        <a class="brand" href="#">khhan.com</a>
        <a href="#education">학력</a>
        <a href="#career">경력</a>
        <a href="#research">연구</a>
        <a href="#qea">QEA</a>
        <a href="#awards">수상</a>
        <a href="#activities">활동</a>
        <a href="#publications">논문·저서</a>
        <a href="#patents">특허</a>
        <a href="#contact">링크</a>
      </div>
    </nav>

    <!-- HERO -->
    <div class="hero">
      <div class="hero-inner">
        <div class="hero-text">
          <h1>한국현 (Kuk-Hyun Han, Ph.D.)</h1>
          <p class="hero-tagline">공학자 · 연구자 · 기업인</p>
          <p><a href="https://www.sym.co.kr" target="_blank" rel="noopener noreferrer" style="color:#4fc3f7;">삼영기계</a> 사장·연구소장 &nbsp;|&nbsp; 순천향대학교 겸임교수
            &nbsp;|&nbsp; 한국주조공학회 부회장 &nbsp;|&nbsp; 한국정밀공학회 이사</p>
          <p style="margin-top:.5rem;">
            <a href={scholarUrl} target="_blank" rel="noopener noreferrer" style="color:#4fc3f7;">Google Scholar</a>
          </p>
        </div>
        <div class="hero-photo-wrap">
          <img
            class="hero-photo"
            src="/assets/images/profile.jpg"
            alt="한국현 (Kuk-Hyun Han)"
            width="120"
            height="152"
            loading="eager"
          />
        </div>
      </div>
    </div>

    <!-- SECTIONS -->
    <Section id="education" title="학력사항">
      <div id="edu-list">
        <ListSection items={educationItems} />
      </div>
    </Section>
    <Section id="career" title="경력사항">
      <div id="career-list">
        <ListSection items={careerItems} />
      </div>
    </Section>

    <section id="research">
      <h2>연구</h2>
      <h3>관심분야</h3>
      <div id="interest-tags" class="tags" set:html={researchInterests.map((t) => `<span class="tag">${escapeHtml(t)}</span>`).join('')}></div>
      <h3>주요 연구과제 (프로젝트)</h3>
      <div id="featured-projects">
        <ListSection items={projectsItems.slice(0, 3)} />
      </div>
      {projectsItems.length > 3 && (
        <>
          <button class="collapse-btn" data-target="projects-list">이전 연구과제 펼치기 / 접기</button>
          <div id="projects-list" class="collapsible">
            <ListSection items={projectsItems.slice(3)} />
          </div>
        </>
      )}
    </section>

    <QeaSection
      qeaAbstract={qeaAbstract}
      qeaThesis={qeaThesis}
      qeaJournals={qeaJournals}
      qeaConferences={qeaConferences}
      qeaDomestic={qeaDomestic}
      qeaPatent={qeaPatent}
    />

    <section id="awards">
      <h2>수상경력</h2>
      <div id="awards-list">
        <ListSection items={awardsItems} />
      </div>
    </section>

    <ActivitiesSection
      boardItems={boardItems}
      committeeItems={committeeItems}
      standardizationItems={standardizationItems}
      talksItems={talksItems}
      teachingItems={teachingItems}
      judgesItems={judgesItems}
      reviewers={activities.reviewers}
    />

    <PublicationsSection
      phdThesis={phdThesis}
      intlJournals={intlJournals}
      intlConferences={intlConferences}
      domesticPapers={domesticPapers}
      magazineArticles={magazineArticles}
      books={books}
    />

    <section id="patents">
      <h2>특허 (Patents)</h2>
      <p id="patent-note">{patentNote}</p>
      <div id="patent-buttons" class="patent-btns" set:html={patentSearchUrls.map((p) => `<a href="${escapeHtml(p.url)}" target="_blank" rel="noopener noreferrer">${escapeHtml(p.label)}</a>`).join('')}></div>
    </section>

    <!-- Honors (collapsible) -->
    <section id="honors">
      <h2>Honors</h2>
      {honors.length > 0 && (
        <>
          <button class="collapse-btn" data-target="honors-list">Honors 펼치기 / 접기</button>
          <div id="honors-list" class="collapsible">
            {honors.map((h) => (
              <div class="item">
                <div class="title" set:html={h.title}></div>
                <FileLinks files={h.files} />
              </div>
            ))}
          </div>
        </>
      )}
    </section>

    <!-- TA activities (collapsible) -->
    <section id="ta">
      <h2>조교활동</h2>
      {taItems.length > 0 && (
        <>
          <button class="collapse-btn" data-target="ta-list">조교활동 펼치기 / 접기</button>
          <div id="ta-list" class="collapsible">
            <ListSection items={taItems} />
          </div>
        </>
      )}
    </section>

    <section id="clubs">
      <h2>동아리활동</h2>
      <div id="clubs-list">
        <ListSection items={clubsItems} />
      </div>
    </section>

    <!-- Contact / Links -->
    <section id="contact">
      <h2>링크</h2>
      <p><a href="http://www.sym.co.kr/" target="_blank" rel="noopener noreferrer" style="color:var(--accent);">삼영기계(주)</a> &nbsp;|&nbsp; <a
          href="http://lumoscandle.com/" target="_blank" rel="noopener noreferrer" style="color:var(--accent);">루모스캔들(주)</a> &nbsp;|&nbsp; <a
          href="https://brunch.co.kr/@breakthrough" target="_blank" rel="noopener noreferrer" style="color:var(--accent);">브런치</a> &nbsp;|&nbsp; <a
          href="https://www.facebook.com/kukhyun.han" target="_blank" rel="noopener noreferrer" style="color:var(--accent);">Facebook</a></p>
    </section>

    <footer>© 2026 한국현 (Kuk-Hyun Han). All rights reserved.</footer>

    <script is:inline>
      document.querySelectorAll('.collapse-btn').forEach((btn) => {
        btn.addEventListener('click', function () {
          const target = document.getElementById(this.dataset.target);
          target.classList.toggle('show');
          this.classList.toggle('open');
        });
      });
    </script>
  </body>
</html>
